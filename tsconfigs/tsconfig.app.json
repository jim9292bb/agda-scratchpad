{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "sourceMap": true,
    "tsBuildInfoFile": "../node_modules/.tmp/app.tsbuildinfo"
  },
  // Path aliases are handled by https://svelte.dev/docs/kit/configuration#alias
  // except $lib which is handled by https://svelte.dev/docs/kit/configuration#files
  //
  // If you want to overwrite includes/excludes, make sure to copy over the relevant includes/excludes
  // from the referenced tsconfig.json - TypeScript does not merge them in
  "include": [
    // copied from .svelte-kit/tsconfig.json removing vite configs
    "../.svelte-kit/ambient.d.ts",
    "../.svelte-kit/non-ambient.d.ts",
    "../.svelte-kit/types/**/$types.d.ts",
    "../src/**/*.js",
    "../src/**/*.ts",
    "../src/**/*.svelte",
    "../tests/**/*.js",
    "../tests/**/*.ts",
    "../tests/**/*.svelte",
    // Outside src/, but imported by src/lib/runtime/interface.ts at build
    // time. The rest of deploy-assets/ is Node-only build tooling, not part
    // of the app bundle, and isn't covered by any tsconfig (same as scripts/).
    // Both generated-*.mjs files don't exist until `npm run setup` (or the
    // predev/precheck/prebuild package.json hooks) generate them — gitignored.
    "../deploy.config.json",
    "../deploy-assets/generated-libraries.mjs",
    "../deploy-assets/generated-als-info.mjs"
  ],
  "exclude": [
    // copied from .svelte-kit/tsconfig.json
    "../node_modules/**",
    "../src/service-worker.js",
    "../src/service-worker/**/*.js",
    "../src/service-worker.ts",
    "../src/service-worker/**/*.ts",
    "../src/service-worker.d.ts",
    "../src/service-worker/**/*.d.ts",
    // exclude tests
    "../src/**/*.spec.js",
    "../src/**/*.spec.ts",
    "../src/**/*.test.js",
    "../src/**/*.test.ts",
    // exclude worker scripts
    "../src/lib/worker/**",
  ]
}
