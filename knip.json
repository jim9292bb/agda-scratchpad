{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app.d.ts",
    "static/coi-serviceworker.js",
    "deploy-assets/ensure-deploy-config.mjs",
    "deploy-assets/build-static-assets.mjs",
    "deploy-assets/generate-manifest.mjs",
    "deploy-assets/build-agdai-cache.mjs",
    "deploy-assets/import-agdai-cache.mjs",
    "deploy-assets/check-agdai-status.mjs",
    "deploy-assets/auto-configure.mjs",
