{
  "name": "agda-scratchpad-ide",
  "version": "0.0.1",
  "description": "Browser-hosted single-file Agda scratchpad IDE for demonstrations, learning, and practice",
  "author": "qbane",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || true",
    "svelte-kit-sync": "svelte-kit sync && rm -f node_modules/.tmp/*.tsbuildinfo",
    "tsc": "tsc -b",
    "check": "npm run svelte-kit-sync && svelte-check --tsconfig ./tsconfigs/tsconfig.app.json",
    "check:watch": "npm run svelte-kit-sync && svelte-check --tsconfig ./tsconfigs/tsconfig.app.json --watch",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "test:browser": "npm run test:browser:core-commands && npm run test:browser:goal-lifecycle && npm run test:browser:damaged-goals && npm run test:browser:load-state && npm run test:browser:commands-panel && npm run test:browser:settings && npm run test:browser:auto && npm run test:browser:queries && npm run test:browser:command-input && npm run test:browser:goal-details && npm run test:browser:libraries && npm run test:browser:errors && npm run test:browser:examples",
    "test:browser:core-commands": "scripts/browser-test-core-commands.sh",
    "test:browser:goal-lifecycle": "scripts/browser-test-goal-lifecycle.sh",
    "test:browser:damaged-goals": "scripts/browser-test-damaged-goal-boundaries.sh",
    "test:browser:load-state": "scripts/browser-test-load-state-refresh.sh",
    "test:browser:commands-panel": "scripts/browser-test-commands-panel.sh",
    "test:browser:settings": "scripts/browser-test-settings-dialog.sh",
    "test:browser:auto": "scripts/browser-test-auto.sh",
    "test:browser:queries": "scripts/browser-test-query-shortcuts.sh",
    "test:browser:command-input": "scripts/browser-test-command-input-panel.sh",
    "test:browser:goal-details": "scripts/browser-test-goal-details.sh",
    "test:browser:libraries": "scripts/browser-test-library-loads.sh",
    "test:browser:errors": "scripts/browser-test-error-display.sh",
    "test:browser:examples": "scripts/browser-test-example-picker.sh"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.53.4",
    "@types/node": "^25.9.1",
    "@typescript-eslint/types": "^8.60.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "svelte": "^5.53.8",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0 <25.0.0"
  },
  "dependencies": {
    "@andy0130tw/vscode-jsonrpc-esm": "^9.0.0-next-esm.9",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/lsp-client": "^6.2.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@quietui/quiet": "file:quietui.tar.gz",
    "@runno/wasi": "^0.10.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "codemirror": "6.0.2",
    "comlink": "^4.4.2",
    "jszip": "^3.10.1",
    "spsc": "^0.0.7",
    "zod": "^4.3.6"
  }
}
