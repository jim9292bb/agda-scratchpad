{
  "name": "als-demo",
  "version": "0.0.1",
  "description": "ALS demo",
  "author": "qbane",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || true",
    "svelte-kit-sync": "svelte-kit sync && rm -f node_modules/.tmp/*.tsbuildinfo",
    "tsc": "tsc -b",
    "check": "npm run svelte-kit-sync && svelte-check --tsconfig ./tsconfigs/tsconfig.app.json",
    "check:watch": "npm run svelte-kit-sync && svelte-check --tsconfig ./tsconfigs/tsconfig.app.json --watch",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.53.4",
    "@types/node": "^25.9.1",
    "@typescript-eslint/types": "^8.60.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "svelte": "^5.53.8",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0 <25.0.0"
  },
  "dependencies": {
    "@andy0130tw/vscode-jsonrpc-esm": "^9.0.0-next-esm.9",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/lsp-client": "^6.2.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@quietui/quiet": "file:quietui.tar.gz",
    "@runno/wasi": "^0.10.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "codemirror": "6.0.2",
    "comlink": "^4.4.2",
    "jszip": "^3.10.1",
    "spsc": "^0.0.7",
    "zod": "^4.3.6"
  }
}
